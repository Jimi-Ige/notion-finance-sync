{
  "name": "notion-finance-sync",
  "version": "0.1.0",
  "description": "Self-hosted CLI that syncs bank transactions into Notion via Plaid. A zero-cost alternative to Finta/Tiller.",
  "type": "module",
  "scripts": {
    "link": "tsx src/link-server.ts",
    "sync": "tsx src/index.ts",
    "status": "tsx src/status.ts",
    "clean": "tsx src/cleanup.ts",
    "import": "tsx src/import-csv.ts",
    "snapshot": "tsx src/snapshot.ts",
    "migrate:budget": "tsx src/migrate-budget.ts",
    "runway": "tsx src/runway.ts",
    "detect": "tsx src/detect-recurring.ts",
    "digest": "tsx src/digest.ts",
    "debt": "tsx src/debt.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "plaid",
    "notion",
    "personal-finance",
    "budget",
    "transactions",
    "self-hosted"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@notionhq/client": "^2.0.0",
    "async-sema": "^3.1.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "plaid": "^41.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
