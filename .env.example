# Plaid API — Register at https://dashboard.plaid.com/signup
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Notion API — Create integration at https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token

# Notion Database IDs
# Find each ID: open database in Notion → Share → Copy link → extract the 32-char hex ID from the URL
# Example URL: https://www.notion.so/myworkspace/abc123def456abc123def456abc123de?v=...
#                                          ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
NOTION_ACCOUNTS_DB=your_accounts_database_id
NOTION_CATEGORIES_DB=your_categories_database_id
NOTION_TRANSACTIONS_DB=your_transactions_database_id
NOTION_BUDGETS_DB=your_budgets_database_id
NOTION_SAVINGS_GOALS_DB=your_savings_goals_database_id

# Encryption passphrase for Plaid access tokens stored at ~/.notion-finance/credentials.json
# If left empty, you'll be prompted interactively when running commands.
CREDENTIAL_PASSPHRASE=
